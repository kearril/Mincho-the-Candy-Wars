<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<JoyKindDef>
		<defName>MCW_MinchoBedJoy</defName>
		<label>mincho relaxation</label>
		<needsThing>false</needsThing>
	</JoyKindDef>

	<ThingDef ParentName="Bed">
		<defName>MCW_MinchoBed</defName>
		<label>mincho bed</label>
		<description>A cozy bed tailored for Mincho.</description>
		<graphicData>
			<texPath>Things/Building/Furniture/Bed/MCW_MinchoBed</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<tickerType>Long</tickerType>
		<comps>
			<li Class="MinchoCandyWars.Buildings.CompProperties_CellTemperatureOverride">
				<temperature>-15</temperature>
			</li>
			<li Class="CompProperties_SelfhealHitpoints">
				<ticksPerHeal>2000</ticksPerHeal>
			</li>
		</comps>
		<statBases>
			<BedHungerRateFactor>1.5</BedHungerRateFactor>
		</statBases>
	</ThingDef>

